{
  "compilerOptions": {
    "rootDir": ".",
    "outDir": "./dist",

    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "target": "ESNext",

    "types": ["node"],

    "sourceMap": true,
    "strict": true,

    "esModuleInterop": true,

    "isolatedModules": true,
    "moduleDetection": "force",
    "skipLibCheck": true
  },

  "include": [
    "src/**/*",
    "api/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist"
  ]
}